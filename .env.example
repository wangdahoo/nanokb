# Nano KB 配置示例 —— 复制为 .env 并按需修改。
# 所有字段前缀 NANOKB_，由 pydantic-settings 自动加载。

# ── LLM ──────────────────────────────────────────────
# provider: openai | anthropic | ollama
NANOKB_LLM_PROVIDER=openai
NANOKB_LLM_MODEL=glm-5.1

# API keys（缺失则对应 provider 启动时 exit code 2）
# NANOKB_OPENAI_API_KEY=sk-...
# NANOKB_ANTHROPIC_API_KEY=sk-ant-...

# Ollama（本地推理，base url）
NANOKB_OLLAMA_BASE_URL=http://localhost:11434

# ── Embedding ────────────────────────────────────────
# provider: openai | ollama
NANOKB_EMBEDDING_PROVIDER=openai
NANOKB_EMBEDDING_MODEL=text-embedding-3-small

# ── 目录 ─────────────────────────────────────────────
NANOKB_RAW_DIR=raw
NANOKB_OUT_DIR=out

# ── 分块 ─────────────────────────────────────────────
NANOKB_CHUNK_MAX_TOKENS=3000
NANOKB_CHUNK_OVERLAP_TOKENS=200

# ── 图谱 / 抽取 ──────────────────────────────────────
NANOKB_GRAPH_SERIALIZATION=json
NANOKB_EXTRACTOR_VERSION=1

# ── 检索 / 问答 ──────────────────────────────────────
NANOKB_RETRIEVAL_HOPS=2
NANOKB_MAX_CONTEXT_TOKENS=4000
NANOKB_FUZZY_MATCH_CUTOFF=0.8
NANOKB_MIN_HIT_COUNT=3
NANOKB_MIN_CONFIDENCE_SCORE=0.3
