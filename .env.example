# Nano KB 配置示例 —— 复制为 .env 并按需修改。
# 所有字段前缀 NANOKB_，由 pydantic-settings 自动加载。

# ── LLM ──────────────────────────────────────────────
# provider: openai | anthropic | ollama
NANOKB_LLM_PROVIDER=openai
NANOKB_LLM_MODEL=glm-5.1

# API keys（缺失则对应 provider 启动时 exit code 2）
# NANOKB_OPENAI_API_KEY=sk-...

# OpenAI 兼容端点（留空=官方 https://api.openai.com/v1 或读 OPENAI_BASE_URL 环境变量）
# 智谱 GLM 示例： NANOKB_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# NANOKB_OPENAI_BASE_URL=

# ── LLM 速率限制（智谱等严格 RPM 供应商必配） ───────────────────
# NANOKB_LLM_MAX_RETRIES=6          # SDK 内置重试次数（429/5xx 自动指数退避）
# NANOKB_LLM_REQUEST_INTERVAL=0.0   # 请求间最小间隔秒数（智谱免费层建议 6.0=10RPM）
# NANOKB_LLM_RATE_LIMIT_RETRIES=3   # SDK 重试耗尽后的应用层 429 补充重试

# Ollama（本地推理，base url）
NANOKB_OLLAMA_BASE_URL=http://localhost:11434

# ── Embedding ────────────────────────────────────────
# provider: openai | ollama
# 注意：用智谱 GLM 时 embedding 需换成智谱模型（如 embedding-3），不能用 OpenAI 的 text-embedding-3-small
NANOKB_EMBEDDING_PROVIDER=openai
NANOKB_EMBEDDING_MODEL=text-embedding-3-small

# Embedding 解耦（生文与向量用不同厂商时配置）。缺失时回退到
# NANOKB_OPENAI_API_KEY / NANOKB_OPENAI_BASE_URL（生文与 embedding 共用，向后兼容）。
# 例 1：生文 DeepSeek + embedding 智谱 GLM embedding-3
#   NANOKB_LLM_PROVIDER=openai
#   NANOKB_LLM_MODEL=deepseek-chat
#   NANOKB_OPENAI_API_KEY=sk-deepseek...
#   NANOKB_OPENAI_BASE_URL=https://api.deepseek.com
#   NANOKB_EMBEDDING_PROVIDER=openai
#   NANOKB_EMBEDDING_MODEL=embedding-3
#   NANOKB_EMBEDDING_API_KEY=<智谱 key>
#   NANOKB_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# 例 2：生文 DeepSeek + embedding 本地 Ollama
#   NANOKB_EMBEDDING_PROVIDER=ollama
#   NANOKB_EMBEDDING_MODEL=nomic-embed-text
#   NANOKB_OLLAMA_BASE_URL=http://localhost:11434
# NANOKB_EMBEDDING_API_KEY=
# NANOKB_EMBEDDING_BASE_URL=

# ── 目录 ─────────────────────────────────────────────
NANOKB_RAW_DIR=raw
NANOKB_OUT_DIR=out

# ── 分块 ─────────────────────────────────────────────
NANOKB_CHUNK_MAX_TOKENS=3000
NANOKB_CHUNK_OVERLAP_TOKENS=200

# ── 图谱 / 抽取 ──────────────────────────────────────
NANOKB_GRAPH_SERIALIZATION=json
NANOKB_EXTRACTOR_VERSION=1

# ── 检索 / 问答 ──────────────────────────────────────
NANOKB_RETRIEVAL_HOPS=2
NANOKB_MAX_CONTEXT_TOKENS=4000
NANOKB_FUZZY_MATCH_CUTOFF=0.8
NANOKB_MIN_HIT_COUNT=3
NANOKB_MIN_CONFIDENCE_SCORE=0.3
